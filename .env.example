# ===== Backend =====
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://oxygen:oxygen@localhost:5432/oxygen?schema=public"

# Redis (for rate limiting, OTP cache, sessions)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-in-prod-please-use-32-bytes-min
JWT_REFRESH_SECRET=change-me-in-prod-please-use-32-bytes-min-too
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Encryption (32-byte hex key for AES-256-GCM PII field encryption)
PII_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# OTP
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
# In dev, all OTPs are forced to this. NEVER set in prod.
OTP_DEV_FIXED=123456

# Vendor APIs (mocked in dev)
KYC_VENDOR=mock
# When ready: KYC_VENDOR=digio | idfy | hyperverge
KYC_VENDOR_API_KEY=
KYC_VENDOR_BASE_URL=

# CORS
ADMIN_WEB_ORIGIN=http://localhost:5173

# ===== Admin Web (Vite reads VITE_*) =====
VITE_API_BASE_URL=http://localhost:3000

# ===== Mobile (passed via flutter --dart-define in CI) =====
# MOBILE_API_BASE_URL=http://10.0.2.2:3000   # Android emulator -> host
