# Production env template — set these as secrets on Render / Fly / etc.
# DO NOT commit a real .env.production with values.

NODE_ENV=production
PORT=3000

# Postgres connection string
# Render: provided automatically via fromDatabase
# Neon:   copy from project dashboard -> Connection Details -> Connection string (direct)
DATABASE_URL=

# 32-byte secrets — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# 32-byte hex (64 chars). Same generator as above. NEVER rotate without re-encrypting existing rows.
PII_ENCRYPTION_KEY=

# OTP
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
# Remove this line for a real launch — it forces every OTP to a known value.
# Once removed, integrate src/auth/otp.service.ts -> sendSms() with MSG91/Gupshup.
OTP_DEV_FIXED=123456

# CORS — comma-separated list of allowed admin web origins (no trailing slash).
# Example: ADMIN_WEB_ORIGIN=https://oxygen-admin.onrender.com,https://staging-admin.oxygen.in
ADMIN_WEB_ORIGIN=

# KYC vendor (mock for early prod; switch to digio/idfy/hyperverge for real go-live)
KYC_VENDOR=mock
KYC_VENDOR_API_KEY=
KYC_VENDOR_BASE_URL=

# Override default seeded admin password (only used on first deploy)
ADMIN_SEED_PASSWORD=
